<mvc:View
  controllerName="sap.cap.p2p.analytical.controller.Main"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:viz="sap.viz.ui5.controls"
  xmlns:viz.data="sap.viz.ui5.data"
  xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">
  <App>
    <pages>
      <Page title="Analytical Page">
        <content>
          <VBox class="sapUiResponsiveContentPadding" renderType="Bare">
            <Title text="Purchase Orders by Status" level="H2" />
            <viz:VizFrame width="100%" height="22rem" vizType="donut" uiConfig="{applicationSet:'fiori'}">
              <viz:dataset>
                <viz.data:FlattenedDataset data="{/POStatusAnalytics}">
                  <viz.data:dimensions>
                    <viz.data:DimensionDefinition name="Status" value="{status}" />
                  </viz.data:dimensions>
                  <viz.data:measures>
                    <viz.data:MeasureDefinition name="Total" value="{total}" />
                  </viz.data:measures>
                </viz.data:FlattenedDataset>
              </viz:dataset>
              <viz:feeds>
                <viz.feeds:FeedItem uid="size" type="Measure" values="Total" />
                <viz.feeds:FeedItem uid="color" type="Dimension" values="Status" />
              </viz:feeds>
            </viz:VizFrame>
            <Title text="Spend by Vendor" level="H2" class="sapUiMediumMarginTop" />
            <Table growing="true" items="{/VendorSpendAnalytics}">
              <columns>
                <Column><Text text="Vendor" /></Column>
                <Column hAlign="End"><Text text="Total Spend" /></Column>
              </columns>
              <items>
                <ColumnListItem>
                  <cells>
                    <Text text="{vendorName}" />
                    <ObjectNumber number="{totalSpend}" unit="INR" />
                  </cells>
                </ColumnListItem>
              </items>
            </Table>
          </VBox>
        </content>
      </Page>
    </pages>
  </App>
</mvc:View>
