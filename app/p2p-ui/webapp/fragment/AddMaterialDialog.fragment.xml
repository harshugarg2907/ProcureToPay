<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns="sap.m">
  <Dialog id="addMaterialDialog" title="Add Material">
    <content>
      <VBox class="sapUiResponsiveMargin">
        <Input placeholder="Material Number" />
        <Input placeholder="Description" />
        <Input placeholder="Base UoM" />
      </VBox>
    </content>
    <beginButton>
      <Button text="Save" press=".onAddMaterial" type="Emphasized" />
    </beginButton>
    <endButton>
      <Button text="Cancel" press=".onCloseDialog" />
    </endButton>
  </Dialog>
</core:FragmentDefinition>
