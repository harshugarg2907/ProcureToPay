{
  "_version": "2.0.0",
  "sap.app": {
    "id": "sap.cap.p2p.ui",
    "type": "application",
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/p2p/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "dependencies": {
      "minUI5Version": "1.136.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.layout": {},
        "sap.f": {},
        "sap.viz": {}
      }
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "preload": false,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true
        }
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "sap.cap.p2p.ui.i18n.i18n"
        }
      },
      "view": {
        "type": "sap.ui.model.json.JSONModel"
      }
    },
    "rootView": {
      "viewName": "sap.cap.p2p.ui.view.App",
      "type": "XML",
      "id": "App"
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "type": "View",
        "viewType": "XML",
        "path": "sap.cap.p2p.ui.view",
        "controlId": "app",
        "controlAggregation": "pages"
      },
      "routes": [
        { "pattern": "login", "name": "login", "target": "login" },
        { "pattern": "", "name": "launchpad", "target": "launchpad" },
        { "pattern": "profile", "name": "profile", "target": "profile" },
        { "pattern": "pr", "name": "purchaseRequisition", "target": "purchaseRequisition" },
        { "pattern": "rfq", "name": "rfq", "target": "rfq" },
        { "pattern": "vendors", "name": "vendors", "target": "vendors" },
        { "pattern": "materials", "name": "materials", "target": "materials" },
        { "pattern": "po", "name": "purchaseOrders", "target": "purchaseOrders" },
        { "pattern": "qc", "name": "qualityInspection", "target": "qualityInspection" },
        { "pattern": "gr", "name": "goodsReceipt", "target": "goodsReceipt" },
        { "pattern": "invoice", "name": "invoice", "target": "invoice" },
        { "pattern": "payment", "name": "paymentRun", "target": "paymentRun" },
        { "pattern": "analytics", "name": "analytics", "target": "analytics" },
        { "pattern": "access-denied", "name": "accessDenied", "target": "accessDenied" }
      ],
      "targets": {
        "login": { "name": "Login", "id": "Login" },
        "launchpad": { "name": "Launchpad", "id": "Launchpad" },
        "profile": { "name": "Profile", "id": "Profile" },
        "purchaseRequisition": { "name": "PurchaseRequisition", "id": "PurchaseRequisition" },
        "rfq": { "name": "RFQ", "id": "RFQ" },
        "vendors": { "name": "Vendor", "id": "Vendor" },
        "materials": { "name": "Material", "id": "Material" },
        "purchaseOrders": { "name": "PurchaseOrder", "id": "PurchaseOrder" },
        "qualityInspection": { "name": "QualityInspection", "id": "QualityInspection" },
        "goodsReceipt": { "name": "GoodsReceipt", "id": "GoodsReceipt" },
        "invoice": { "name": "Invoice", "id": "Invoice" },
        "paymentRun": { "name": "PaymentRun", "id": "PaymentRun" },
        "analytics": { "name": "Analytics", "id": "Analytics" },
        "accessDenied": { "name": "AccessDenied", "id": "AccessDenied" }
      }
    }
  }
}
