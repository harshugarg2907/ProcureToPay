<mvc:View
  controllerName="sap.cap.p2p.transactional.controller.Main"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m">
  <App>
    <pages>
      <Page id="mainPage" title="{page>/pageTitle}">
        <content>
          <IconTabBar expandable="false" selectedKey="{page>/selectedKey}" class="sapUiResponsiveContentPadding p2pCard">
            <items>
              <IconTabFilter key="qc" text="Inspection Lots" icon="sap-icon://inspection" visible="{page>/showInspectionLots}">
                <Table id="inspectionTable" class="p2pResponsiveTable" growing="true" mode="SingleSelectMaster" selectionChange=".onSelectInspectionLot" items="{/InspectionLots}">
                  <headerToolbar>
                    <OverflowToolbar>
                      <Title text="Inspection Lots" />
                      <ToolbarSpacer />
                      <Button text="Post Usage Decision" icon="sap-icon://accept" type="Emphasized" visible="{actions>/postUsageDecision}" press=".onPostUsageDecision" />
                    </OverflowToolbar>
                  </headerToolbar>
                  <columns>
                    <Column><Text text="Lot" /></Column>
                    <Column><Text text="Material" /></Column>
                    <Column><Text text="Status" /></Column>
                  </columns>
                  <items>
                    <ColumnListItem type="Navigation">
                      <cells>
                        <ObjectIdentifier title="{inspectionLotNo}" />
                        <Text text="{material/materialNo}" />
                        <ObjectStatus text="{status}" />
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
              </IconTabFilter>
              <IconTabFilter key="gr" text="Goods Receipts" icon="sap-icon://shipping-status" visible="{page>/showGoodsReceipts}">
                <Table class="p2pResponsiveTable" growing="true" mode="SingleSelectMaster" selectionChange=".onSelectGoodsReceipt" items="{/GoodsReceipts}">
                  <columns>
                    <Column><Text text="GR" /></Column>
                    <Column><Text text="Posting Date" /></Column>
                    <Column><Text text="Status" /></Column>
                  </columns>
                  <items>
                    <ColumnListItem type="Navigation">
                      <cells>
                        <ObjectIdentifier title="{grNo}" />
                        <Text text="{postingDate}" />
                        <ObjectStatus text="{status}" />
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
              </IconTabFilter>
              <IconTabFilter key="invoice" text="Invoices" icon="sap-icon://expense-report" visible="{page>/showInvoices}">
                <Table id="invoiceTable" class="p2pResponsiveTable" growing="true" mode="SingleSelectMaster" selectionChange=".onSelectInvoice" items="{/Invoices}">
                  <headerToolbar>
                    <OverflowToolbar>
                      <Title text="Invoices" />
                      <ToolbarSpacer />
                      <Button text="Three-Way Match" icon="sap-icon://compare" visible="{actions>/runThreeWayMatch}" press=".onRunThreeWayMatch" />
                      <Button text="Payment Advice" icon="sap-icon://payment-approval" type="Emphasized" visible="{actions>/createPaymentAdvice}" press=".onCreatePaymentAdvice" />
                    </OverflowToolbar>
                  </headerToolbar>
                  <columns>
                    <Column><Text text="Invoice" /></Column>
                    <Column><Text text="Vendor" /></Column>
                    <Column hAlign="End"><Text text="Payable" /></Column>
                    <Column><Text text="Status" /></Column>
                  </columns>
                  <items>
                    <ColumnListItem type="Navigation">
                      <cells>
                        <ObjectIdentifier title="{invoiceNo}" />
                        <Text text="{vendor/name}" />
                        <ObjectNumber number="{totalPayable}" unit="{currency}" />
                        <ObjectStatus text="{status}" />
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
              </IconTabFilter>
              <IconTabFilter key="payment" text="Payment Runs" icon="sap-icon://payment-approval" visible="{page>/showPaymentRuns}">
                <Table id="paymentTable" class="p2pResponsiveTable" growing="true" mode="SingleSelectMaster" selectionChange=".onSelectPaymentRun" items="{/PaymentRuns}">
                  <headerToolbar>
                    <OverflowToolbar>
                      <Title text="Payment Runs" />
                      <ToolbarSpacer />
                      <Button text="Execute Payment Run" icon="sap-icon://process" type="Emphasized" visible="{actions>/executePaymentRun}" press=".onExecutePaymentRun" />
                    </OverflowToolbar>
                  </headerToolbar>
                  <columns>
                    <Column><Text text="Run" /></Column>
                    <Column><Text text="Run Date" /></Column>
                    <Column hAlign="End"><Text text="Amount" /></Column>
                    <Column><Text text="Status" /></Column>
                  </columns>
                  <items>
                    <ColumnListItem type="Navigation">
                      <cells>
                        <ObjectIdentifier title="{paymentRunId}" />
                        <Text text="{runDate}" />
                        <ObjectNumber number="{totalPaymentAmount}" />
                        <ObjectStatus text="{status}" />
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
              </IconTabFilter>
            </items>
          </IconTabBar>
        </content>
      </Page>
    </pages>
  </App>
</mvc:View>
