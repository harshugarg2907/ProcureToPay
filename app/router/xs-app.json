{
  "authenticationMethod": "route",
  "logout": {
    "logoutEndpoint": "/logout",
    "logoutPage": "/logged-out.html"
  },
  "errorPage": [
    {
      "status": 404,
      "file": "./not-found.html"
    }
  ],
  "routes": [
    {
      "source": "^/odata/(.*)$",
      "target": "/odata/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/not-found\\.html$",
      "localDir": ".",
      "target": "not-found.html",
      "authenticationType": "none"
    },
    {
      "source": "^/logged-out\\.html$",
      "localDir": ".",
      "target": "logged-out.html",
      "authenticationType": "none"
    },
    {
      "source": "^/(.*)$",
      "localDir": "resources",
      "target": "$1",
      "authenticationType": "xsuaa"
    }
  ]
}
