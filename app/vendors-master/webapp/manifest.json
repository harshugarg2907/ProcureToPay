{
  "_version": "2.0.0",
  "sap.app": {
    "id": "sap.cap.p2p.vendors",
    "type": "application",
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/p2p/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "dependencies": {
      "minUI5Version": "1.136.0",
      "libs": {
        "sap.fe.core": {},
        "sap.fe.templates": {},
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "preload": false,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true
        }
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "sap.cap.p2p.vendors.i18n.i18n"
        }
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router"
      },
      "routes": [
        {
          "pattern": ":?query:",
          "name": "VendorsList",
          "target": "VendorsList"
        },
        {
          "pattern": "Vendors({key}):?query:",
          "name": "VendorsObjectPage",
          "target": "VendorsObjectPage"
        }
      ],
      "targets": {
        "VendorsList": {
          "type": "Component",
          "id": "VendorsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "Vendors",
              "liveMode": true,
              "navigation": {
                "Vendors": {
                  "detail": {
                    "route": "VendorsObjectPage"
                  }
                }
              }
            }
          }
        },
        "VendorsObjectPage": {
          "type": "Component",
          "id": "VendorsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet": "Vendors"
            }
          }
        }
      }
    }
  }
}
