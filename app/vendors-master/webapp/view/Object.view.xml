<mvc:View
  controllerName="sap.cap.p2p.vendors.controller.Object"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f">
  <Page title="Vendor Master Object Page">
    <headerContent>
      <Button icon="sap-icon://home" tooltip="Dashboard" press=".openDashboard" />
    </headerContent>
    <content>
      <f:FlexibleColumnLayout id="layout" layout="TwoColumnsMidExpanded">
        <f:beginColumnPages>
          <Page title="Vendors">
            <content>
              <List growing="true" items="{/Vendors}" mode="SingleSelectMaster" selectionChange=".onVendorSelected">
                <items>
                  <ObjectListItem
                    title="{name}"
                    number="{vendorNo}"
                    intro="{city}"
                    type="Active">
                    <attributes>
                      <ObjectAttribute title="Payment Terms" text="{paymentTerms}" />
                      <ObjectAttribute title="Currency" text="{currency}" />
                    </attributes>
                    <firstStatus>
                      <ObjectStatus text="{status}" />
                    </firstStatus>
                  </ObjectListItem>
                </items>
              </List>
            </content>
          </Page>
        </f:beginColumnPages>
        <f:midColumnPages>
          <Page id="detailPage" title="Vendor Details">
            <content>
              <ObjectHeader
                title="{name}"
                number="{vendorNo}"
                intro="{city}">
                <attributes>
                  <ObjectAttribute title="Payment Terms" text="{paymentTerms}" />
                  <ObjectAttribute title="Currency" text="{currency}" />
                  <ObjectAttribute title="Status" text="{status}" />
                </attributes>
              </ObjectHeader>
              <IconTabBar expandable="false" class="sapUiResponsiveContentPadding">
                <items>
                  <IconTabFilter text="Materials" icon="sap-icon://product">
                    <Table growing="true" items="{/Materials}">
                      <columns>
                        <Column><Text text="Material" /></Column>
                        <Column><Text text="Description" /></Column>
                        <Column><Text text="Plant" /></Column>
                        <Column hAlign="End"><Text text="Price" /></Column>
                      </columns>
                      <items>
                        <ColumnListItem>
                          <cells>
                            <ObjectIdentifier title="{materialNo}" />
                            <Text text="{description}" />
                            <Text text="{plant}" />
                            <ObjectNumber number="{movingAvgPrice}" unit="INR" />
                          </cells>
                        </ColumnListItem>
                      </items>
                    </Table>
                  </IconTabFilter>
                  <IconTabFilter text="Purchase Orders" icon="sap-icon://sales-order">
                    <Table growing="true" items="{/PurchaseOrders}">
                      <columns>
                        <Column><Text text="PO Number" /></Column>
                        <Column><Text text="Vendor" /></Column>
                        <Column hAlign="End"><Text text="Net Value" /></Column>
                        <Column><Text text="Status" /></Column>
                      </columns>
                      <items>
                        <ColumnListItem>
                          <cells>
                            <ObjectIdentifier title="{poNo}" />
                            <Text text="{vendor/name}" />
                            <ObjectNumber number="{totalNetValue}" unit="INR" />
                            <ObjectStatus text="{status}" />
                          </cells>
                        </ColumnListItem>
                      </items>
                    </Table>
                  </IconTabFilter>
                </items>
              </IconTabBar>
            </content>
          </Page>
        </f:midColumnPages>
      </f:FlexibleColumnLayout>
    </content>
  </Page>
</mvc:View>
