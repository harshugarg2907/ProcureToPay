{
  "name": "sap-cap-p2p",
  "version": "1.0.0",
  "description": "SAP CAP full stack Procure-to-Pay application",
  "private": true,
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "deploy": "cds deploy --to sqlite",
    "build:router-resources": "node scripts/copy-router-resources.js",
    "build:mta": "mbt build",
    "deploy:cf": "cf deploy mta_archives/sap-cap-p2p_1.0.0.mtar",
    "lint:ui5": "cd app/p2p-ui && ui5lint && cd ../dashboard && ui5lint && cd ../procurement-pages && ui5lint && cd ../p2p-list-object && ui5lint && cd ../p2p-analytical && ui5lint && cd ../p2p-transactional && ui5lint && cd ../p2p-object-pages && ui5lint",
    "test": "npm run deploy"
  },
  "dependencies": {
    "@cap-js/hana": "^2",
    "@cap-js/sqlite": "^2.4.0",
    "@sap/cds": "^9.9.1",
    "@sap/xssec": "^4",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9.9.2",
    "@ui5/cli": "^4.0.16",
    "@ui5/linter": "^1.21.2",
    "cds-plugin-ui5": "^0.12.0"
  },
  "cds": {
    "requires": {
      "db": {
        "[development]": {
          "kind": "sqlite",
          "credentials": {
            "url": "db.sqlite"
          }
        },
        "[production]": {
          "kind": "hana"
        }
      },
      "auth": {
        "[development]": {
          "kind": "dummy",
          "users": {
            "admin": {
              "password": "admin",
            "roles": [
                "P2P_ADMIN",
                "authenticated-user"
              ]
            },
            "jsmith": {
              "password": "jsmith",
            "roles": [
                "P2P_BUYER",
                "authenticated-user"
              ]
            },
            "qinspector": {
              "password": "qinspector",
            "roles": [
                "P2P_QUALITY_INSPECTOR",
                "authenticated-user"
              ]
            },
            "grofficer": {
              "password": "grofficer",
            "roles": [
                "P2P_BUYER",
                "authenticated-user"
              ]
            },
            "finance": {
              "password": "finance",
            "roles": [
                "P2P_FINANCE_MANAGER",
                "authenticated-user"
              ]
            },
            "viewer": {
              "password": "viewer",
            "roles": [
                "P2P_REQUESTER",
                "authenticated-user"
              ]
            }
          }
        },
        "[production]": {
          "kind": "xsuaa"
        }
      },
      "[production]": {
        "auth": {
          "kind": "xsuaa"
        }
      }
    },
    "odata": {
      "version": "v4"
    }
  }
}
