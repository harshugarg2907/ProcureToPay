{
  "xsappname": "sap-cap-p2p",
  "tenant-mode": "dedicated",
  "scopes": [
    {
      "name": "$XSAPPNAME.P2P_ADMIN",
      "description": "Full Procure-to-Pay administration access"
    },
    {
      "name": "$XSAPPNAME.P2P_BUYER",
      "description": "Buyer access for requisitions, RFQs, purchase orders, vendors, and materials"
    },
    {
      "name": "$XSAPPNAME.P2P_REQUESTER",
      "description": "Requester access for purchase requisitions"
    },
    {
      "name": "$XSAPPNAME.P2P_VENDOR_MANAGER",
      "description": "Vendor and supplier master data access"
    },
    {
      "name": "$XSAPPNAME.P2P_QUALITY_INSPECTOR",
      "description": "Quality inspection access"
    },
    {
      "name": "$XSAPPNAME.P2P_AP_CLERK",
      "description": "Accounts payable invoice verification access"
    },
    {
      "name": "$XSAPPNAME.P2P_FINANCE_MANAGER",
      "description": "Payment processing and finance approval access"
    }
  ],
  "role-templates": [
    {
      "name": "P2P_ADMIN",
      "description": "Procure-to-Pay Administrator",
      "scope-references": [
        "$XSAPPNAME.P2P_ADMIN"
      ]
    },
    {
      "name": "P2P_BUYER",
      "description": "Procure-to-Pay Buyer",
      "scope-references": [
        "$XSAPPNAME.P2P_BUYER"
      ]
    },
    {
      "name": "P2P_REQUESTER",
      "description": "Procure-to-Pay Requester",
      "scope-references": [
        "$XSAPPNAME.P2P_REQUESTER"
      ]
    },
    {
      "name": "P2P_VENDOR_MANAGER",
      "description": "Procure-to-Pay Vendor Manager",
      "scope-references": [
        "$XSAPPNAME.P2P_VENDOR_MANAGER"
      ]
    },
    {
      "name": "P2P_QUALITY_INSPECTOR",
      "description": "Procure-to-Pay Quality Inspector",
      "scope-references": [
        "$XSAPPNAME.P2P_QUALITY_INSPECTOR"
      ]
    },
    {
      "name": "P2P_AP_CLERK",
      "description": "Procure-to-Pay Accounts Payable Clerk",
      "scope-references": [
        "$XSAPPNAME.P2P_AP_CLERK"
      ]
    },
    {
      "name": "P2P_FINANCE_MANAGER",
      "description": "Procure-to-Pay Finance Manager",
      "scope-references": [
        "$XSAPPNAME.P2P_FINANCE_MANAGER"
      ]
    }
  ],
  "attributes": []
}
